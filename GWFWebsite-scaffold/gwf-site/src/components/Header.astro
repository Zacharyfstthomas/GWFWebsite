---
interface Props {
  currentPage: 'home' | 'about' | 'staff' | 'ledger';
}

const { currentPage } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const nav = [
  { key: 'home', label: 'Home', href: `${base}/` },
  { key: 'about', label: 'About', href: `${base}/about/` },
  { key: 'staff', label: 'Board & Staff', href: `${base}/staff/` },
  { key: 'ledger', label: 'Ledger', href: `${base}/ledger/` },
] as const;
---

<header class="site-header">
  <div class="container header-inner">
    <a href={`${base}/`} class="wordmark" aria-label="Gamecock Wrestling Foundation — home">
      <span class="wordmark-mark" aria-hidden="true">G·W·F</span>
      <span class="wordmark-divider" aria-hidden="true"></span>
      <span class="wordmark-full">
        <span class="wordmark-name">Gamecock Wrestling Foundation</span>
        <span class="wordmark-est">Est. MMXXV · South Carolina</span>
      </span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <ul>
        {nav.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={['nav-link', { 'is-current': item.key === currentPage }]}
              aria-current={item.key === currentPage ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a href={`${base}/ledger/`} class="btn header-cta">
      Give <span class="btn-arrow"></span>
    </a>

    <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="mobile-nav" aria-label="Toggle navigation">
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>
  </div>

  <nav id="mobile-nav" class="mobile-nav" aria-label="Primary mobile" hidden>
    <ul>
      {nav.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={['mobile-nav-link', { 'is-current': item.key === currentPage }]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--rule);
    background: var(--cream);
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(8px);
    background-color: color-mix(in srgb, var(--cream) 92%, transparent);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding-block: 1.1rem;
  }

  .wordmark {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    text-decoration: none;
    color: var(--ink);
  }

  .wordmark-mark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.4rem;
    letter-spacing: 0.05em;
    color: var(--garnet);
    font-variation-settings: 'opsz' 144;
  }

  .wordmark-divider {
    width: 1px;
    height: 2rem;
    background: var(--rule);
  }

  .wordmark-full {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .wordmark-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.02rem;
    line-height: 1;
    font-variation-settings: 'opsz' 24;
  }

  .wordmark-est {
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .site-nav {
    margin-left: auto;
  }

  .site-nav ul {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    position: relative;
    padding-block: 0.35rem;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1.5px;
    background: var(--garnet);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-link:hover::after,
  .nav-link.is-current::after {
    transform: scaleX(1);
  }

  .nav-link.is-current {
    color: var(--garnet);
  }

  .header-cta {
    padding: 0.6rem 1.15rem;
    font-size: 0.88rem;
  }

  .nav-toggle {
    display: none;
    margin-left: auto;
    background: transparent;
    border: 1px solid var(--rule);
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 4px;
  }

  .nav-toggle-bar {
    width: 1.1rem;
    height: 1.5px;
    background: var(--ink);
    transition: transform 0.2s ease;
  }

  .mobile-nav {
    border-top: 1px solid var(--rule);
    padding: 1rem var(--page-pad);
  }

  .mobile-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .mobile-nav-link {
    display: block;
    padding: 0.75rem 0;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--rule-soft);
  }

  .mobile-nav-link.is-current {
    color: var(--garnet);
  }

  @media (max-width: 900px) {
    .wordmark-full {
      display: none;
    }

    .wordmark-divider {
      display: none;
    }

    .site-nav,
    .header-cta {
      display: none;
    }

    .nav-toggle {
      display: flex;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const mobileNav = document.querySelector<HTMLElement>('#mobile-nav');

  if (toggle && mobileNav) {
    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!isOpen));
      if (isOpen) {
        mobileNav.setAttribute('hidden', '');
      } else {
        mobileNav.removeAttribute('hidden');
      }
    });
  }
</script>
