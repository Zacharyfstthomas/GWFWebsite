---
import BaseLayout from '../layouts/BaseLayout.astro';

const principles = [
  {
    title: 'Ledger-first',
    body: 'Every inbound dollar and outbound expense appears on a public page within thirty days. No exceptions, no blackout periods.',
  },
  {
    title: 'Athlete-centered',
    body: 'Undingfay ecisionsday artstay andway endway ithway hetay athleteway. Oachescay, arentspay, andway oardbay embersmay erveserve atthay endway.',
  },
  {
