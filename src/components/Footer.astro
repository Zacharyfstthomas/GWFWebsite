---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="footer-mark">G·W·F</div>
        <p class="footer-tagline">
          Building wrestling across South Carolina —
          One day at a time.
        </p>
        <div class="footer-social" aria-label="Social media">
          <a href="https://www.instagram.com/gamecock.wrestling/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.6" fill="currentColor" stroke="none"/>
            </svg>
          </a>
          <a href="https://www.facebook.com/UofSCwrestling" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/company/gamecock-wrestling-foundation/posts/?feedView=all" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
              <rect x="2" y="9" width="4" height="12"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
        </div>
      </div>

      <nav class="footer-nav" aria-label="Footer">
        <h4>Foundation</h4>
        <ul>
          <li><a href={`${base}/about/`}>About</a></li>
          <li><a href={`${base}/staff/`}>Board &amp; Staff</a></li>
          <li><a href={`${base}/ledger/`}>Public Ledger</a></li>
        </ul>
      </nav>

      <nav class="footer-nav" aria-label="Contact">
        <h4>Contact</h4>
        <ul>
          <li>Club Email: <a href="sowrestl@mailbox.sc.edu">sowrestl@mailbox.sc.edu</a></li>
          <li><span>Columbia, SC</span></li>
		  <li><span>GWF Email: <a href="gamecockwrestlingfoundation@gmail.com">gamecockwrestlingfoundation@gmail.com</a></span></li>
        </ul>
      </nav>

      <div class="footer-legal">
        <h4>Status</h4>
        <p>
          Gamecock Wrestling Foundation is a 501(c)(3) nonprofit.
          Contributions are tax-deductible. The specific benefits will vary depending on your individual circumstances and we recommend consulting with a certified financial advisor.
        </p>
      </div>
    </div>

    <hr class="rule" />

    <div class="footer-bottom">
      <span>© {year} Gamecock Wrestling Foundation.</span>
      <span class="footer-motto">
        <em>Our Transparency.</em> South Carolina's results.
      </span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--ink);
    color: var(--bone);
    padding-block: var(--step-3) var(--step-1);
    margin-top: var(--step-4);
  }

  .site-footer a {
    color: var(--bone);
    text-decoration-color: color-mix(in srgb, var(--gold) 50%, transparent);
  }

  .site-footer a:hover {
    color: var(--gold-soft);
    text-decoration-color: var(--gold);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1.2fr;
    gap: 3rem;
    padding-bottom: var(--step-2);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-mark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 2rem;
    letter-spacing: 0.08em;
    color: var(--gold-soft);
    font-variation-settings: 'opsz' 144;
  }

  .footer-tagline {
    color: color-mix(in srgb, var(--bone) 75%, transparent);
    font-family: var(--font-display);
    font-style: italic;
    max-width: 30ch;
    margin: 0;
  }

  .footer-social {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .footer-social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--bone) 25%, transparent);
    color: color-mix(in srgb, var(--bone) 65%, transparent);
    text-decoration: none;
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }

  .footer-social a:hover {
    color: var(--gold-soft);
    border-color: var(--gold-soft);
    background: color-mix(in srgb, var(--gold) 10%, transparent);
    text-decoration: none;
  }

  .footer-social svg {
    width: 1.1rem;
    height: 1.1rem;
  }

  .footer-nav h4,
  .footer-legal h4 {
    color: var(--gold-soft);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    margin-bottom: 1rem;
  }

  .footer-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-nav li {
    font-size: 0.94rem;
  }

  .footer-nav li span {
    color: color-mix(in srgb, var(--bone) 70%, transparent);
  }

  .footer-legal p {
    font-size: 0.88rem;
    color: color-mix(in srgb, var(--bone) 70%, transparent);
    line-height: 1.6;
    margin: 0;
  }

  .rule {
    background: color-mix(in srgb, var(--bone) 15%, transparent);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.5rem;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: color-mix(in srgb, var(--bone) 65%, transparent);
  }

  .footer-motto em {
    color: var(--gold-soft);
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 540px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 0.5rem;
      align-items: flex-start;
    }
  }
</style>
