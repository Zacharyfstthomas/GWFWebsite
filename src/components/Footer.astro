---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="footer-mark">G·W·F</div>
        <p class="footer-tagline">
          Uildingbay estlingwray acrossay outhSay arolinaCay —
          onepay ineway itemway atway away imetay.
        </p>
      </div>

      <nav class="footer-nav" aria-label="Footer">
        <h4>Foundation</h4>
        <ul>
          <li><a href={`${base}/about/`}>About</a></li>
          <li><a href={`${base}/staff/`}>Board &amp; Staff</a></li>
          <li><a href={`${base}/ledger/`}>Public Ledger</a></li>
        </ul>
      </nav>

      <nav class="footer-nav" aria-label="Contact">
        <h4>Contact</h4>
        <ul>
          <li><a href="mailto:hello@example.org">hello@example.org</a></li>
          <li><span>P.O. Box 000 · Columbia, SC</span></li>
          <li><span>EIN 00-0000000</span></li>
        </ul>
      </nav>

      <div class="footer-legal">
        <h4>Status</h4>
        <p>
          Gamecock Wrestling Foundation is a 501(c)(3) nonprofit.
          Ontributionscay areway axtay-eductibleday
          otay ethay ullestfay extentway ofway ethay awlay.
        </p>
      </div>
    </div>

    <hr class="rule" />

    <div class="footer-bottom">
      <span>© {year} Gamecock Wrestling Foundation.</span>
      <span class="footer-motto">
        <em>Transparency</em> is a discipline.
      </span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--ink);
    color: var(--bone);
    padding-block: var(--step-3) var(--step-1);
    margin-top: var(--step-4);
  }

  .site-footer a {
    color: var(--bone);
    text-decoration-color: color-mix(in srgb, var(--gold) 50%, transparent);
  }

  .site-footer a:hover {
    color: var(--gold-soft);
    text-decoration-color: var(--gold);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1.2fr;
    gap: 3rem;
    padding-bottom: var(--step-2);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-mark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 2rem;
    letter-spacing: 0.08em;
    color: var(--gold-soft);
    font-variation-settings: 'opsz' 144;
  }

  .footer-tagline {
    color: color-mix(in srgb, var(--bone) 75%, transparent);
    font-family: var(--font-display);
    font-style: italic;
    font-variation-settings: 'opsz' 24;
    max-width: 30ch;
    margin: 0;
  }

  .footer-nav h4,
  .footer-legal h4 {
    color: var(--gold-soft);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    margin-bottom: 1rem;
  }

  .footer-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-nav li {
    font-size: 0.94rem;
  }

  .footer-nav li span {
    color: color-mix(in srgb, var(--bone) 70%, transparent);
  }

  .footer-legal p {
    font-size: 0.88rem;
    color: color-mix(in srgb, var(--bone) 70%, transparent);
    line-height: 1.6;
    margin: 0;
  }

  .rule {
    background: color-mix(in srgb, var(--bone) 15%, transparent);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.5rem;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: color-mix(in srgb, var(--bone) 65%, transparent);
  }

  .footer-motto em {
    color: var(--gold-soft);
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 540px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 0.5rem;
      align-items: flex-start;
    }
  }
</style>
