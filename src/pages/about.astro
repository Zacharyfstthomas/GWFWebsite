---
import BaseLayout from '../layouts/BaseLayout.astro';

const principles = [
  {
    title: 'Straightforward Ledger',
    body: 'Every inbound dollar and outbound expense appears on a public page within thirty days. No exceptions.',
  },
  {
    title: 'Athlete-centered',
    body: 'Our purpose as alumni is to ensure that these athletes are able to achieve their absolute best with only their academics and training to focus on. We are driven to keep the beauracrats and busywork out of their way, to give them the same opportunities we had.'
  },
  {
    title: 'Compounding impact',
    body: 'By being an early day contributor, you can help build the infrastructure now for these young men to pursue competition and growth whenever and wherever it is available.',
  },

];
---

<BaseLayout
  title="About"
  pageKey="about"
  description="About the Gamecock Wrestling Foundation — mission, story, and governing principles."
>
  <section class="about-hero">
    <div class="container">
      <p class="eyebrow reveal reveal-1">About</p>
      <h1 class="reveal reveal-2">
        A foundation <em>built</em> on<br />
        one simple idea: show<br />
        the receipts.
      </h1>
      <p class="lede reveal reveal-3">
        The Gamecock Wrestling Foundation is a South Carolina nonprofit
        focused on the growth of wrestling — from the youth club to the
        NCWA mats. This page explains who we are, how we work,
        and what you can expect when you give.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container two-col">
      <div>
        <p class="eyebrow">Mission</p>
        <h2>Grow the sport</h2>
      </div>
      <div class="prose">
        <p>
          Placeholder.
        </p>
        <p>
         Placeholder.
        </p>
        <p>
          Placeholder.
        </p>
      </div>
    </div>
  </section>

  <section class="section section-muted">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">Principles</p>
        <h2>Four rules we run by.</h2>
      </header>

      <div class="principles">
        {principles.map((p, i) => (
          <article class="principle">
            <div class="principle-num num">0{i + 1}</div>
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container two-col">
      <div>
        <p class="eyebrow">Story</p>
        <h2>A short history.</h2>
      </div>
      <div class="prose">
        <p>
          Founded in 2025,
          Placeholders.
        </p>
        <p>
          This is a placeholder.
        </p>
        <p>
          In 2026, we placed two University of South Carolina wrestlers as All-Americans at the NCWA National Wrestling Championships.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero {
    padding-block: clamp(3rem, 8vw, 6rem) var(--step-2);
  }

  .about-hero h1 em {
    font-style: italic;
    font-weight: 400;
    color: var(--garnet);
    font-variation-settings: 'opsz' 144;
  }

  .two-col {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.6fr);
    gap: 4rem;
    align-items: start;
  }

  .two-col h2 {
    position: sticky;
    top: 6rem;
  }

  .prose p {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--ink-soft);
  }

  .prose p:first-child::first-letter {
    font-family: var(--font-display);
    font-size: 3.4rem;
    font-weight: 500;
    float: left;
    line-height: 0.95;
    margin: 0.12em 0.12em 0 0;
    color: var(--garnet);
    font-variation-settings: 'opsz' 144;
  }

  .section-muted {
    background: var(--bone);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .section-head {
    margin-bottom: var(--step-2);
    max-width: 42rem;
  }

  .principles {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0;
    border-top: 1px solid var(--rule);
    border-left: 1px solid var(--rule);
  }

  .principle {
    padding: 2.25rem 2rem;
    border-bottom: 1px solid var(--rule);
    border-right: 1px solid var(--rule);
  }

  .principle-num {
    font-size: 0.88rem;
    letter-spacing: 0.2em;
    color: var(--garnet);
    margin-bottom: 2rem;
  }

  .principle p {
    color: var(--ink-muted);
    margin: 0;
  }

  @media (max-width: 900px) {
    .two-col {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .two-col h2 { position: static; }
    .principles { grid-template-columns: 1fr; }
  }
</style>
