---
import BaseLayout from '../layouts/BaseLayout.astro';
import LedgerTable from '../components/LedgerTable.astro';
import { loadLedger, loadCategories, summarize, formatUSD } from '../lib/ledger';

const rows = loadLedger();
const categories = loadCategories();
const summary = summarize(rows);

const usedCategories = Array.from(new Set(rows.map((r) => r.category)));

// Percent of expense total for each category with any expense activity
const expenseBreakdown = Object.entries(summary.byCategory)
  .filter(([, v]) => v.expense > 0)
  .map(([label, v]) => ({
    label,
    expense: v.expense,
    pct: summary.totalExpense > 0 ? (v.expense / summary.totalExpense) * 100 : 0,
    count: v.count,
  }))
  .sort((a, b) => b.expense - a.expense);

const lastUpdated = rows.length > 0 ? rows[0].date : '';
---

<BaseLayout
  title="Ledger"
  pageKey="ledger"
  description="Public ledger of every dollar the Gamecock Wrestling Foundation receives and spends."
>
  <section class="ledger-hero">
    <div class="container">
      <p class="eyebrow reveal reveal-1">Public Ledger</p>
      <h1 class="reveal reveal-2">
        Every <em>dollar</em>. Every<br />
        <em>line item</em>. On the record.
      </h1>
      <p class="lede reveal reveal-3">
        Atthay isway ourway edgerlay. Everyway ansactiontray,
        everyway ategorycay, everyway ethodmay. Ilterfay ybay ategorycay,
        earchsay ybay ordway, oray ownloadday ethay awray ataday elowbay.
      </p>

      <div class="ledger-stats reveal reveal-4">
        <div class="stat">
          <p class="stat-label">Total income</p>
          <p class="stat-value num">{formatUSD(summary.totalIncome)}</p>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat">
          <p class="stat-label">Total expense</p>
          <p class="stat-value num">{formatUSD(summary.totalExpense)}</p>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat">
          <p class="stat-label">Net on reserve</p>
          <p class="stat-value num">{formatUSD(summary.net)}</p>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat">
          <p class="stat-label">Last updated</p>
          <p class="stat-value num">
            {lastUpdated ? new Date(lastUpdated + 'T00:00:00Z').toLocaleDateString('en-US', {
              month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC',
            }) : '—'}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Expense breakdown bar -->
  <section class="section-thin breakdown-section">
    <div class="container">
      <header class="breakdown-head">
        <div>
          <p class="eyebrow">Where it goes</p>
          <h2>Expense breakdown</h2>
        </div>
        <p class="breakdown-sub">
          Of every dollar deployed to mission so far:
        </p>
      </header>

      <div class="breakdown-bar" role="img" aria-label="Expense breakdown by category">
        {expenseBreakdown.map((c, i) => (
          <div
            class="breakdown-segment"
            style={`width: ${c.pct}%`}
            data-variant={`v-${(i % 4) + 1}`}
            title={`${c.label} — ${formatUSD(c.expense)} (${c.pct.toFixed(1)}%)`}
          ></div>
        ))}
      </div>

      <ul class="breakdown-legend">
        {expenseBreakdown.map((c, i) => (
          <li class="breakdown-row">
            <span class="breakdown-dot" data-variant={`v-${(i % 4) + 1}`} aria-hidden="true"></span>
            <span class="breakdown-label">{c.label}</span>
            <span class="breakdown-pct num">{c.pct.toFixed(1)}%</span>
            <span class="breakdown-amt num">{formatUSD(c.expense)}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Ledger table -->
  <section class="section">
    <div class="container">
      <header class="section-head section-head-split">
        <div>
          <p class="eyebrow">The record</p>
          <h2>Every transaction.</h2>
        </div>
        <a href="./data/ledger.csv" class="btn btn-ghost" download>
          Download CSV <span class="btn-arrow"></span>
        </a>
      </header>

      <LedgerTable rows={rows} categories={usedCategories} />

      <p class="ledger-disclaimer">
        Ledger is currently underdevelopment. Any questions,
        <a href="mailto:zacharyfstthomas@gmail.org">contact the treasurer</a>.
      </p>
    </div>
  </section>

  <!-- Category definitions -->
  <section class="section section-muted">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">Category key</p>
        <h2>What each bucket means.</h2>
      </header>

      <dl class="category-defs">
        {categories.map((c) => (
          <div class="category-def">
            <dt>{c.label}</dt>
            <dd>{c.description}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>
</BaseLayout>

<style>
  .ledger-hero {
    padding-block: clamp(3rem, 8vw, 6rem) var(--step-2);
  }

  .ledger-hero h1 em {
    font-style: italic;
    font-weight: 400;
    color: var(--garnet);
    font-variation-settings: 'opsz' 144;
  }

  /* Stats strip */

  .ledger-stats {
    display: flex;
    gap: 0;
    margin-top: var(--step-2);
    border: 1px solid var(--rule);
    background: var(--bone);
    flex-wrap: wrap;
  }

  .stat {
    flex: 1 1 10rem;
    padding: 1.5rem 1.75rem;
  }

  .stat-divider {
    width: 1px;
    background: var(--rule);
    align-self: stretch;
  }

  .stat-label {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin: 0 0 0.4rem;
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2vw, 1.85rem);
    font-weight: 500;
    margin: 0;
    font-variant-numeric: tabular-nums;
    line-height: 1;
    font-variation-settings: 'opsz' 144;
  }

  /* Breakdown */

  .breakdown-section {
    padding-bottom: var(--step-2);
  }

  .breakdown-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .breakdown-head h2 {
    margin: 0;
  }

  .breakdown-sub {
    color: var(--ink-muted);
    font-style: italic;
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 24;
    margin: 0;
  }

  .breakdown-bar {
    display: flex;
    height: 2.5rem;
    border-radius: 2px;
    overflow: hidden;
    background: var(--bone-soft);
    border: 1px solid var(--rule);
  }

  .breakdown-segment {
    height: 100%;
    transition: filter 0.15s ease;
    border-right: 1px solid rgba(255, 255, 255, 0.25);
  }

  .breakdown-segment:last-child {
    border-right: none;
  }

  .breakdown-segment:hover {
    filter: brightness(0.92);
  }

  [data-variant='v-1'] { background: var(--garnet); }
  [data-variant='v-2'] { background: var(--ink); }
  [data-variant='v-3'] { background: var(--gold); }
  [data-variant='v-4'] { background: var(--garnet-bright); }

  .breakdown-legend {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: 0.5rem 2rem;
  }

  .breakdown-row {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    gap: 0.75rem;
    align-items: baseline;
    padding-block: 0.45rem;
    font-size: 0.9rem;
    border-bottom: 1px solid var(--rule-soft);
  }

  .breakdown-dot {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 2px;
  }

  .breakdown-label {
    color: var(--ink);
  }

  .breakdown-pct {
    color: var(--ink-muted);
    font-size: 0.82rem;
  }

  .breakdown-amt {
    font-weight: 600;
    color: var(--ink);
  }

  /* Section heads */

  .section-head {
    margin-bottom: var(--step-2);
    max-width: 42rem;
  }

  .section-head-split {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    max-width: none;
    flex-wrap: wrap;
  }

  .section-head-split h2 { margin-bottom: 0; }

  .section-muted {
    background: var(--bone);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  /* Disclaimer */

  .ledger-disclaimer {
    margin-top: 1.5rem;
    color: var(--ink-muted);
    font-size: 0.9rem;
    font-style: italic;
  }

  /* Category defs */

  .category-defs {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0;
    border-top: 1px solid var(--rule);
    border-left: 1px solid var(--rule);
    margin: 0;
  }

  .category-def {
    padding: 1.5rem 1.75rem;
    border-bottom: 1px solid var(--rule);
    border-right: 1px solid var(--rule);
  }

  .category-def dt {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.1rem;
    color: var(--garnet-deep);
    margin-bottom: 0.5rem;
    font-variation-settings: 'opsz' 24;
  }

  .category-def dd {
    margin: 0;
    color: var(--ink-muted);
    font-size: 0.92rem;
  }

  @media (max-width: 900px) {
    .category-defs { grid-template-columns: 1fr; }
    .stat { flex: 1 1 100%; }
    .stat-divider { display: none; }
  }
</style>
