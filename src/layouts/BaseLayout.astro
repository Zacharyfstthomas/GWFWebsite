---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  pageKey?: 'home' | 'about' | 'staff' | 'ledger';
}

const {
  title,
  description = 'The Gamecock Wrestling Foundation builds wrestling across South Carolina — and publishes every dollar that passes through our hands.',
  pageKey = 'home',
} = Astro.props;

const siteTitle =
  pageKey === 'home' ? 'Gamecock Wrestling Foundation' : `${title} — GWF`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
    <title>{siteTitle}</title>
  </head>
  <body>
    <a class="visually-hidden" href="#main">Skip to main content</a>
    <Header currentPage={pageKey} />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
